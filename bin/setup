#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)
full_reset = ARGV.include?("--full")

def system!(*args)
  system(*args, exception: true)
end

begin
  FileUtils.chdir APP_ROOT do
    puts "== Installing JS dependencies =="
    system! "yarn install"

    puts "\n== Installing Ruby dependencies =="
    system! "gem install bundler --conservative"
    system("bundle check") || system!("bundle install")

    if full_reset
      puts "\n== Resetting database =="
      system! "bundle exec rake db:drop"
    end

    puts "\n== Creating and migrating database =="
    system! "bundle exec rake db:create db:migrate"

    puts "\n== Seeding database =="
    system! "bundle exec rake db:seed"

    puts "\n== Installing foreman =="
    system! "gem install foreman"

    puts "\n== Removing old logs and tempfiles =="
    system! "bin/rails log:clear tmp:clear"

    puts "\n== Setup complete! =="
    puts "Run 'foreman start -f Procfile.dev' to start the server."
  end
rescue RuntimeError => e
  puts "\n!! Setup failed: #{e.message}"
  puts "!! Try running 'bin/setup --full' to drop and recreate the database from scratch."
  exit 1
end
