#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

offset=$(printf '%s' "$PWD" | cksum | awk '{print $1 % 100}')

if [ ! -f .env ]; then
  cat > .env <<EOF
# Auto-generated by bin/dev for this worktree. Edit freely; bin/dev won't overwrite.
PORT=$((3000 + offset))
VITE_RUBY_PORT=$((3100 + offset))
APP_BASE_URL=http://127.0.0.1:$((3000 + offset))
DATABASE_NAME=cctv_development_${offset}
TEST_DATABASE_NAME=cctv_test_${offset}
EOF
  echo "→ Created .env for this worktree (offset=${offset})."
  echo "  Run 'bin/rails db:create db:schema:load db:seed' to set up its database."
fi

set -a
# shellcheck disable=SC1091
source .env
set +a

export PORT="${PORT:-$((3000 + offset))}"
export VITE_RUBY_PORT="${VITE_RUBY_PORT:-$((3100 + offset))}"
export APP_BASE_URL="${APP_BASE_URL:-http://127.0.0.1:${PORT}}"

echo "→ Rails http://127.0.0.1:${PORT}  Vite http://127.0.0.1:${VITE_RUBY_PORT}  DB ${DATABASE_NAME:-cctv_development}"

exec yarn concurrently --kill-others -n vite,tailwind,web -c blue,magenta,green \
  "ruby bin/vite dev" \
  "yarn tailwind:watch" \
  "ruby bin/rails s -b 0.0.0.0 -p ${PORT}"
