#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

bin/wt-env

set -a
# shellcheck disable=SC1091
source .env
set +a

offset=$(printf '%s' "$PWD" | cksum | awk '{print $1 % 100}')
export PORT="${PORT:-$((3000 + offset))}"
export VITE_RUBY_PORT="${VITE_RUBY_PORT:-$((3100 + offset))}"
export APP_BASE_URL="${APP_BASE_URL:-http://127.0.0.1:${PORT}}"

echo "→ Rails http://127.0.0.1:${PORT}  Vite http://127.0.0.1:${VITE_RUBY_PORT}  DB ${DATABASE_NAME:-cctv_development}"

exec yarn concurrently --kill-others -n vite,tailwind,web -c blue,magenta,green \
  "ruby bin/vite dev" \
  "yarn tailwind:watch" \
  "ruby bin/rails s -b 0.0.0.0 -p ${PORT}"
