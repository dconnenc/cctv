<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "cctv" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#080808">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script>
      (function() {
        try {
          var d = document.documentElement;
          var t = localStorage.getItem('ui.theme');
          if (t !== 'light' && t !== 'dark') {
            t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          d.setAttribute('data-theme', t);
          if (t === 'dark') d.classList.add('dark'); else d.classList.remove('dark');
          var tc = document.querySelector('meta[name="theme-color"]');
          if (tc) tc.setAttribute('content', t === 'dark' ? '#080808' : '#f0ede4');
          var bg = localStorage.getItem('ui.bgAnimated');
          d.setAttribute('data-bg', bg === 'false' ? 'solid' : 'animated');
        } catch (e) { /* no-op */ }
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;900&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">

    <link rel="apple-touch-icon" href="/icon.png">
    <%= vite_react_refresh_tag %>
    <%= vite_client_tag %>
    <%= vite_typescript_tag 'application.tsx' %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
