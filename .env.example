GEMINI_API_KEY=your_gemini_api_key_here

# bin/setup and bin/dev auto-generate .env per worktree (via bin/wt-env).
# Values below are derived from a hash of the worktree path so each worktree
# gets unique ports and its own database. You can edit .env freely afterward —
# regeneration won't overwrite it.
#
# PORT=3000
# VITE_RUBY_PORT=3100
# APP_BASE_URL=http://127.0.0.1:3000
# DATABASE_NAME=cctv_development
# TEST_DATABASE_NAME=cctv_test
#
CCTV_AWS_ACCESS_KEY_ID=your_aws_access_key_id
CCTV_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
CCTV_AWS_S3_BUCKET=cctv-photo-bucket-dev